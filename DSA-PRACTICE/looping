#include <math.h>
int main()
{
   int n,nod=0,sum=0;
   scanf("%d",&n);
   int temp=n;
   nod=log10(n)+1;
   if(n>=0&&n<=9) printf("it is amstrong number");
   while(n){
       int last=n%10;
       sum+=pow(last,nod);
       n/=10;
   }
   if(sum==temp) printf("it is amstrong number");
   else printf("it is not amstrong number");
    return 0;
}

