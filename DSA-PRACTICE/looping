#include <stdio.h>
# include<math.h>
int main()
{
    int n,sum=0;
    scanf("%d",&n);
    for(int i=1;i<sqrt(n);i++){
        if(n%i==0) {
            sum+=i;
            if(n/i!=n) sum+=n/i;}
        
    }
    if(sum==n) printf("it is perfect number");
    else if(sum<n) printf("it is defecit number");
    else printf("it is abudant number");
    
    

    return 0;
}

