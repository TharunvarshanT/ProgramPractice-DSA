#include <stdio.h>

int main()
{
    int n = 6;
    int mid = n / 2;

    if(n % 2 == 0)
        mid--;

    for(int i = 1; i <= n; i++)
    {
        for(int j = 1; j <= n; j++)
        {
            if(i == mid + 1 ||
               j == mid + i ||
               i + j == n + mid + 1)
                printf("* ");
            else
                printf("  ");
        }
        printf("\n");
    }

    return 0;
}

